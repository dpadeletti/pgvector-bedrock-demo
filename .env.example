# Database Configuration (AWS RDS PostgreSQL)
DB_HOST=your-rds-endpoint.eu-north-1.rds.amazonaws.com
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your-secure-password

# AWS Configuration
AWS_REGION=eu-north-1
AWS_BEDROCK_MODEL_ID=amazon.titan-embed-text-v2:0

# Note:
# - Copia questo file in .env e inserisci i tuoi valori reali
# - Non committare .env nel repository (è già in .gitignore)
# - Le credenziali AWS vengono lette da AWS CLI configurata
# - Titan V2 usa embeddings di 1024 dimensioni (non 1536 come V1)
